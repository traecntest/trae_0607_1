@page "/monitoring"
@inject IDroneStateStore DroneStateStore
@inject IConflictDetector ConflictDetector
@implements IAsyncDisposable

<PageTitle>实时监控 - UTM 管理系统</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="page-title mb-0">实时监控</h1>
            <p class="page-subtitle mb-0">实时监控所有无人机的运行状态</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="d-flex align-items-center gap-2">
                <span class="status-dot @(AutoRefresh ? "status-online" : "bg-secondary")" style="width: 10px; height: 10px; border-radius: 50%; display: inline-block;"></span>
                <span class="small text-muted">
                    @(AutoRefresh ? "自动刷新中" : "手动刷新")
                </span>
            </div>
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" @bind="AutoRefresh" id="autoRefreshSwitch">
                <label class="form-check-label" for="autoRefreshSwitch">自动刷新</label>
            </div>
            <select class="form-select" style="width: 120px;" @bind="RefreshInterval">
                <option value="1">1 秒</option>
                <option value="2">2 秒</option>
                <option value="5">5 秒</option>
                <option value="10">10 秒</option>
            </select>
            <button class="btn btn-primary" @onclick="RefreshDataAsync">
                <i class="bi bi-arrow-clockwise"></i> 刷新
            </button>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-2">
            <div class="stat-card stat-blue">
                <div class="stat-value">@TotalDrones</div>
                <div class="stat-label">无人机总数</div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="stat-card stat-green">
                <div class="stat-value">@FlyingCount</div>
                <div class="stat-label">飞行中</div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="stat-card stat-orange">
                <div class="stat-value">@HoveringCount</div>
                <div class="stat-label">悬停</div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="stat-card stat-cyan">
                <div class="stat-value">@ConflictCount</div>
                <div class="stat-label">活动冲突</div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card h-100">
                <div class="card-body text-center">
                    <div class="text-muted small mb-1">平均高度</div>
                    <div class="h4 mb-0">@AvgAltitude.ToString("F1") m</div>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card h-100">
                <div class="card-body text-center">
                    <div class="text-muted small mb-1">平均速度</div>
                    <div class="h4 mb-0">@AvgSpeed.ToString("F1") m/s</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>无人机实时状态列表</span>
            <span class="text-muted small">最后更新: @LastUpdate.ToString("HH:mm:ss.fff")</span>
        </div>
        <div class="card-body p-0">
            @if (AllDrones.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-sm">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>状态</th>
                                <th>经度</th>
                                <th>纬度</th>
                                <th>高度 (m)</th>
                                <th>速度 (m/s)</th>
                                <th>航向</th>
                                <th>电量</th>
                                <th>安全半径</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var drone in AllDrones.OrderBy(d => d.Id))
                            {
                                <tr>
                                    <td>
                                        <a href="/drones/@drone.Id" class="text-decoration-none fw-medium">
                                            @drone.Id
                                        </a>
                                    </td>
                                    <td>
                                        <span class="badge badge-@drone.Status.ToString().ToLower()">
                                            @GetStatusShort(drone.Status)
                                        </span>
                                    </td>
                                    <td class="font-monospace small">@drone.CurrentPosition.Longitude.ToString("F6")</td>
                                    <td class="font-monospace small">@drone.CurrentPosition.Latitude.ToString("F6")</td>
                                    <td>@drone.CurrentPosition.Altitude.ToString("F1")</td>
                                    <td>@GetSpeed(drone.Velocity).ToString("F2")</td>
                                    <td>@GetHeading(drone.Velocity)°</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2" style="width: 120px;">
                                            <div class="progress flex-grow-1" style="height: 6px;">
                                                <div class="progress-bar @GetBatteryClass(drone.BatteryLevel)" style="width:@drone.BatteryLevel%"></div>
                                            </div>
                                            <span class="small">@drone.BatteryLevel.ToString("F0")%</span>
                                        </div>
                                    </td>
                                    <td>@drone.SafetyRadius m</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state py-5">
                    <div class="empty-state-icon">📡</div>
                    <p>暂无无人机数据</p>
                    <p class="small text-muted">启动模拟器以生成模拟数据</p>
                    <a href="/simulation" class="btn btn-primary">前往模拟器</a>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool AutoRefresh = true;
    private int RefreshInterval = 2;
    private List<Drone> AllDrones = new();
    private List<ConflictDetectedEvent> Conflicts = new();
    private DateTime LastUpdate = DateTime.Now;
    private Timer? _refreshTimer;

    private int TotalDrones => AllDrones.Count;
    private int FlyingCount => AllDrones.Count(d => d.Status == DroneStatus.Flying);
    private int HoveringCount => AllDrones.Count(d => d.Status == DroneStatus.Hovering);
    private int ConflictCount => Conflicts.Count;

    private double AvgAltitude => AllDrones.Any() ? AllDrones.Average(d => d.CurrentPosition.Altitude) : 0;
    private double AvgSpeed => AllDrones.Any() ? AllDrones.Average(d => GetSpeed(d.Velocity)) : 0;

    protected override async Task OnInitializedAsync()
    {
        await RefreshDataAsync();
        if (AutoRefresh)
        {
            StartAutoRefresh();
        }
    }

    private void StartAutoRefresh()
    {
        _refreshTimer = new Timer(
            async _ => await InvokeAsync(async () =>
            {
                await RefreshDataAsync();
                StateHasChanged();
            }),
            null,
            TimeSpan.FromSeconds(RefreshInterval),
            TimeSpan.FromSeconds(RefreshInterval));
    }

    private void StopAutoRefresh()
    {
        _refreshTimer?.Dispose();
        _refreshTimer = null;
    }

    private async Task RefreshDataAsync()
    {
        AllDrones = DroneStateStore.GetAllDrones().ToList();
        Conflicts = await ConflictDetector.DetectConflictsAsync(AllDrones);
        LastUpdate = DateTime.Now;
    }

    private static double GetSpeed(Velocity3D velocity)
    {
        return Math.Sqrt(velocity.East * velocity.East +
                        velocity.North * velocity.North +
                        velocity.Up * velocity.Up);
    }

    private static double GetHeading(Velocity3D velocity)
    {
        if (velocity.East == 0 && velocity.North == 0)
            return 0;
        var heading = Math.Atan2(velocity.East, velocity.North) * 180 / Math.PI;
        if (heading < 0) heading += 360;
        return Math.Round(heading, 1);
    }

    private static string GetStatusShort(DroneStatus status)
    {
        return status switch
        {
            DroneStatus.Idle => "待机",
            DroneStatus.Flying => "飞行",
            DroneStatus.Hovering => "悬停",
            DroneStatus.Landing => "降落",
            DroneStatus.Landed => "着陆",
            DroneStatus.TakingOff => "起飞",
            DroneStatus.Emergency => "紧急",
            _ => status.ToString()
        };
    }

    private static string GetBatteryClass(double battery)
    {
        if (battery > 50) return "bg-success";
        if (battery > 20) return "bg-warning";
        return "bg-danger";
    }

    public async ValueTask DisposeAsync()
    {
        if (_refreshTimer != null)
        {
            await _refreshTimer.DisposeAsync();
        }
    }
}
