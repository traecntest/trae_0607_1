@page "/conflicts"
@inject IDroneStateStore DroneStateStore
@inject IConflictDetector ConflictDetector

<PageTitle>冲突告警 - UTM 管理系统</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="page-title mb-0">冲突告警</h1>
            <p class="page-subtitle mb-0">实时监控与管理飞行冲突</p>
        </div>
        <div class="d-flex gap-2">
            <select class="form-select" style="width: 150px;" @bind="SeverityFilter">
                <option value="">全部等级</option>
                <option value="Critical">危急</option>
                <option value="High">高</option>
                <option value="Medium">中</option>
                <option value="Low">低</option>
            </select>
            <button class="btn btn-primary" @onclick="RefreshDataAsync">
                <i class="bi bi-arrow-clockwise"></i> 刷新
            </button>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <div class="h2 text-danger mb-0">@CriticalCount</div>
                    <div class="text-muted small">危急冲突</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <div class="h2 text-warning mb-0">@HighCount</div>
                    <div class="text-muted small">高风险冲突</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-info">
                <div class="card-body text-center">
                    <div class="h2 text-info mb-0">@MediumCount</div>
                    <div class="text-muted small">中风险冲突</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-secondary">
                <div class="card-body text-center">
                    <div class="h2 text-secondary mb-0">@LowCount</div>
                    <div class="text-muted small">低风险冲突</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>冲突列表</span>
            <div class="d-flex align-items-center gap-3">
                <span class="text-muted small">
                    检测参数: 安全距离 @ConflictDetector.SafetyDistance m | 
                    预测范围 @ConflictDetector.PredictionHorizon s
                </span>
                <span class="text-muted small">最后更新: @LastUpdate.ToString("HH:mm:ss")</span>
            </div>
        </div>
        <div class="card-body p-0">
            @if (FilteredConflicts.Any())
            {
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>序号</th>
                            <th>无人机</th>
                            <th>严重程度</th>
                            <th>最近会遇时间</th>
                            <th>最近会遇距离</th>
                            <th>预测位置</th>
                            <th>检测时间</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < FilteredConflicts.Count; i++)
                        {
                            var conflict = FilteredConflicts[i];
                            <tr class="table-@GetSeverityTableClass(conflict.Severity)">
                                <td>@(i + 1)</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        @foreach (var droneId in conflict.DroneIds)
                                        {
                                            <a href="/drones/@droneId" class="badge bg-light text-dark text-decoration-none">
                                                @droneId
                                            </a>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <span class="badge badge-@conflict.Severity.ToString().ToLower()">
                                        @GetSeverityText(conflict.Severity)
                                    </span>
                                </td>
                                <td>
                                    @if (conflict.TimeToCollision < 10)
                                    {
                                        <span class="text-danger fw-bold">
                                            @conflict.TimeToCollision.ToString("F1") 秒
                                        </span>
                                    }
                                    else
                                    {
                                        <span>@conflict.TimeToCollision.ToString("F1") 秒</span>
                                    }
                                </td>
                                <td>
                                    @if (conflict.MinimumDistance < 30)
                                    {
                                        <span class="text-danger fw-bold">
                                            @conflict.MinimumDistance.ToString("F1") m
                                        </span>
                                    }
                                    else
                                    {
                                        <span>@conflict.MinimumDistance.ToString("F1") m</span>
                                    }
                                </td>
                                <td class="font-monospace small">
                                    <div>@conflict.PredictedCollisionPoint.Longitude.ToString("F4")°E</div>
                                    <div>@conflict.PredictedCollisionPoint.Latitude.ToString("F4")°N</div>
                                    <div>@conflict.PredictedCollisionPoint.Altitude.ToString("F1") m</div>
                                </td>
                                <td class="text-muted small">
                                    @conflict.DetectedAt.ToString("HH:mm:ss")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state py-5">
                    <div class="empty-state-icon">✅</div>
                    <p>当前没有检测到冲突</p>
                    <p class="small text-muted">所有无人机飞行安全</p>
                </div>
            }
        </div>
    </div>

    @if (SelectedConflict != null)
    {
        <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">冲突详情 - @string.Join(" ↔ ", SelectedConflict.DroneIds)</h5>
                        <button type="button" class="btn-close" @onclick="() => SelectedConflict = null"></button>
                    </div>
                    <div class="modal-body">
                        <p>冲突详情信息</p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="() => SelectedConflict = null">
                            关闭
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private string SeverityFilter = string.Empty;
    private List<ConflictDetectedEvent> AllConflicts = new();
    private DateTime LastUpdate = DateTime.Now;
    private ConflictDetectedEvent? SelectedConflict;

    private int CriticalCount => AllConflicts.Count(c => c.Severity == ConflictSeverity.Critical);
    private int HighCount => AllConflicts.Count(c => c.Severity == ConflictSeverity.High);
    private int MediumCount => AllConflicts.Count(c => c.Severity == ConflictSeverity.Medium);
    private int LowCount => AllConflicts.Count(c => c.Severity == ConflictSeverity.Low);

    private List<ConflictDetectedEvent> FilteredConflicts
    {
        get
        {
            var query = AllConflicts.AsEnumerable();
            if (!string.IsNullOrWhiteSpace(SeverityFilter))
            {
                var severity = Enum.Parse<ConflictSeverity>(SeverityFilter);
                query = query.Where(c => c.Severity == severity);
            }
            return query.OrderBy(c => c.TimeToCollision).ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await RefreshDataAsync();
    }

    private async Task RefreshDataAsync()
    {
        var allDrones = DroneStateStore.GetAllDrones().ToList();
        AllConflicts = await ConflictDetector.DetectConflictsAsync(allDrones);
        LastUpdate = DateTime.Now;
    }

    private static string GetSeverityText(ConflictSeverity severity)
    {
        return severity switch
        {
            ConflictSeverity.Low => "低",
            ConflictSeverity.Medium => "中",
            ConflictSeverity.High => "高",
            ConflictSeverity.Critical => "危急",
            _ => severity.ToString()
        };
    }

    private static string GetSeverityTableClass(ConflictSeverity severity)
    {
        return severity switch
        {
            ConflictSeverity.Critical => "danger",
            ConflictSeverity.High => "warning",
            ConflictSeverity.Medium => "info",
            _ => ""
        };
    }
}
